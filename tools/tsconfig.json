{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "module": "node16",
    "moduleResolution": "node16",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "allowJs": true,
    "rootDir": ".",
    "verbatimModuleSyntax": false,
    "types": ["jest", "node"]
  },
  "include": ["."],
  "exclude": ["lib"]
}
